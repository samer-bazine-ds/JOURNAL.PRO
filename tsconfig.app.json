{
  "compilerOptions": {
    "target": "ES2022", "useDefineForClassFields": true, "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "allowJs": true, "checkJs": false, "module": "ESNext", "skipLibCheck": true,
    "moduleResolution": "Bundler", "allowImportingTsExtensions": true, "resolveJsonModule": true,
    "isolatedModules": true, "esModuleInterop": true, "jsx": "react-jsx", "strict": true, "noEmit": true
  },
  "include": ["src", "pdf-parser.js"]
}
